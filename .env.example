# Local env. Copy to .env.local and fill in. .env.local is gitignored.

# ---- Admin auth ----
#
# Set these in the Netlify dashboard for production:
#   Site → Site configuration → Environment variables.
# Both must be set or /login + /admin/* return 503.
#
# Generate SESSION_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_PASSWORD=change-me
SESSION_SECRET=replace-with-a-random-string

# ---- Content folder location ----
#
# Where the scanner looks for Nicholas's source images.
# Leave unset (or comment out) to use the bundled <project>/content folder.
# Set this to point at a Google-Drive-synced folder on your machine so
# Nicholas can drop images into Drive and have them appear in the picker:
#
#   Windows:  CONTENT_ROOT=G:\My Drive\Khan Art Site — content
#   Mac:      CONTENT_ROOT=/Users/<you>/Library/CloudStorage/GoogleDrive-<email>/My Drive/Khan Art Site — content
#
# See docs/google-drive-sync.md for the full Drive-for-Desktop setup.
# CONTENT_ROOT=
