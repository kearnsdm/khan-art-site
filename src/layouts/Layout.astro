---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SideNav from "../components/SideNav.astro";
import type { SectionId } from "../data/sections";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  section?: SectionId | null;
  workSlug?: string;
  /** When set, highlights the matching tag-based menu item. */
  currentTagId?: string | null;
  /** When set, highlights the matching year-range child of the Works group. */
  currentYearGroupId?: string | null;
  /** True on the /works landing page — highlights the Works parent link. */
  isWorksHome?: boolean;
}

const {
  title = "Nicholas Hart Khan — Visual Artist",
  description = "Paintings and portraits by Nicholas Hart Khan.",
  section = null,
  workSlug,
  currentTagId = null,
  currentYearGroupId = null,
  isWorksHome = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap"
    />
  </head>
  <body>
    <Header />

    <!-- Mobile-only hamburger toggle. Shown ≤ 820 px; on desktop the
         CSS hides this and the side nav is always visible in the grid. -->
    <button
      type="button"
      class="nav-toggle"
      id="nav-toggle"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="side-nav"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18" />
      </svg>
    </button>

    <div class="page-layout">
      <SideNav
        currentSection={section}
        currentWorkSlug={workSlug}
        currentTagId={currentTagId}
        currentYearGroupId={currentYearGroupId}
        isWorksHome={isWorksHome}
      />
      <main>
        <slot />
      </main>
    </div>
    <Footer />

    <a class="admin-key" href="/login" aria-label="Sign in" title="Sign in">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M14.5 4a5.5 5.5 0 0 0-5.32 6.92L2 18.1V22h3.9l1.4-1.4v-1.8h1.8l1.4-1.4v-1.8h1.8l1.6-1.6A5.5 5.5 0 1 0 14.5 4Zm2 6a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z" />
      </svg>
    </a>

    <script is:inline>
      (function () {
        const toggle = document.getElementById("nav-toggle");
        const nav = document.getElementById("side-nav");
        if (!toggle || !nav) return;
        function setOpen(open) {
          nav.classList.toggle("mobile-open", open);
          toggle.setAttribute("aria-expanded", String(open));
          document.body.classList.toggle("nav-mobile-open", open);
        }
        toggle.addEventListener("click", () => {
          const open = toggle.getAttribute("aria-expanded") !== "true";
          setOpen(open);
        });
        // Tap a real navigation link → close. Disclosure carets and
        // toggle-only buttons inside the nav don't get this treatment.
        nav.querySelectorAll("a").forEach((a) => {
          a.addEventListener("click", () => setOpen(false));
        });
        // Escape key closes the menu on mobile.
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && nav.classList.contains("mobile-open")) {
            setOpen(false);
            toggle.focus();
          }
        });
        // Resizing back to desktop should drop the mobile-open state so
        // the nav doesn't sit in a weird half-open layout if someone
        // rotates a tablet or resizes a window.
        const mq = window.matchMedia("(max-width: 820px)");
        function onMqChange(e) {
          if (!e.matches) setOpen(false);
        }
        if (mq.addEventListener) mq.addEventListener("change", onMqChange);
        else mq.addListener(onMqChange);
      })();
    </script>

    <style>
      /* Hamburger toggle. Hidden on desktop; the side nav is in the
         grid as usual. On mobile (≤ 820 px) we hide the side nav by
         default and reveal it via this button. */
      .nav-toggle {
        display: none;
      }
      @media (max-width: 820px) {
        .nav-toggle {
          position: fixed;
          top: 0.8rem;
          right: 0.8rem;
          z-index: 90;
          width: 44px;
          height: 44px;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          padding: 0;
          background: var(--color-panel, #faf6ec);
          color: var(--color-accent, #1a1a1a);
          border: 1px solid var(--color-rule, #d6cfbe);
          cursor: pointer;
          box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }
        .nav-toggle svg {
          width: 22px;
          height: 22px;
          fill: none;
          stroke: currentColor;
          stroke-width: 2;
          stroke-linecap: round;
        }
        .nav-toggle[aria-expanded="true"] {
          background: var(--color-accent, #1a1a1a);
          color: var(--color-bg, #f1ebde);
        }
      }

      .admin-key {
        position: fixed;
        bottom: 0.85rem;
        right: 0.85rem;
        width: 22px;
        height: 22px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--color-muted, #6a6457);
        opacity: 0.35;
        transition: opacity 0.15s ease;
        z-index: 100;
        text-decoration: none;
      }
      .admin-key:hover,
      .admin-key:focus-visible {
        opacity: 1;
        outline: none;
      }
      .admin-key svg {
        width: 100%;
        height: 100%;
        fill: currentColor;
      }
    </style>
  </body>
</html>
