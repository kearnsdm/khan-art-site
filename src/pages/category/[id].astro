---
import Layout from "../../layouts/Layout.astro";
import WorkCard from "../../components/WorkCard.astro";
import GalleryControls from "../../components/GalleryControls.astro";
import { loadWorksData, worksByTag } from "../../data/works";
import { loadTags } from "../../data/tags";

// SSR: the previous getStaticPaths produced one prerendered page per
// tag at build time. With tags editable at runtime that snapshot can
// drift, so we look the tag up fresh per request instead.
const id = Astro.params.id;
const tags = await loadTags();
const tag = id ? tags.find((t) => t.id === id) : undefined;
if (!tag) {
  return new Response("Not found", { status: 404 });
}

const data = await loadWorksData();
const list = worksByTag(data, tag.id);
---

<Layout title={`${tag.label} — Nicholas Hart Khan`} currentTagId={tag.id}>
  <h2 class="page-title">{tag.label}</h2>
  {list.length === 0 ? (
    <p class="prose" style="text-align:center;color:var(--color-muted);">
      No works tagged "{tag.label}" yet.
    </p>
  ) : (
    <>
      <GalleryControls />
      <section class="gallery-grid">
        {list.map((work) => <WorkCard work={work} />)}
      </section>
    </>
  )}
</Layout>
