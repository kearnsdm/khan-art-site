---
import Layout from "../layouts/Layout.astro";

// To receive real submissions when deployed, paste a Formspree (or Netlify
// Forms) endpoint URL here, e.g. "https://formspree.io/f/abc123". Until
// then, the form shows an inline thank-you and does nothing.
const formAction = "";
---

<Layout title="About — Nicholas Hart Khan" section="bio">
  <article class="about-page">
    <section id="about" class="about-section">
      <h2 class="page-title">About</h2>

      <!-- Bio paragraphs sit on the left; two portrait photos stack
           vertically on the right column on desktop. On phones the
           whole right column moves above the bio text so it stays
           readable and the photos appear side-by-side at the top. -->
      <div class="bio-layout">
        <div class="bio-photos">
          <figure>
            <img
              src="/about/nicholas-portrait.jpg"
              alt="Nicholas Khan standing in front of one of his paintings"
              loading="eager"
            />
          </figure>
          <figure>
            <img
              src="/about/nicholas-painting.jpg"
              alt="Nicholas Khan painting his own self-portrait"
              loading="eager"
            />
          </figure>
        </div>
        <div class="prose bio-text">
          <p>
            Nicholas Khan is a visual artist based in Raleigh, North Carolina
            and formerly in Connecticut. He specializes as a painter of
            landscapes, architecture, and abstracts. He also has experience in
            portraiture, installations, and colorizing photos of historical
            buildings.
          </p>
          <p>
            He received his B.A. from Eastern Connecticut State University in
            2017 where he studied with Andy Jones, Qimin Liu and Afarin
            Rahmanifar. His major also included art history, where he studied
            the history of the Hudson River School, frame history and design,
            and vernacular Victorian architecture in New England.
          </p>
          <p>
            In 2021 Nicholas graduated from the MFA program at the School of
            the Museum of Fine Arts at Tufts University (Boston). His work
            there explored narratives of identity as it relates to private
            and public spaces as well as the histories of those places.
          </p>
        </div>
      </div>
    </section>

    <section id="contact" class="about-section">
      <h2 class="page-title">Contact</h2>
      <div class="contact-page">
        <div class="contact-info">
          <p class="contact-email">
            Email: <a href="mailto:nicholashartkhan@gmail.com">nicholashartkhan@gmail.com</a>
          </p>
          <form
            class="contact-form"
            method="POST"
            action={formAction || "#"}
            data-needs-endpoint={formAction ? undefined : "true"}
          >
            <p class="form-row">
              <label for="contact-name">Your name</label>
              <input id="contact-name" name="name" type="text" required autocomplete="name" />
            </p>
            <p class="form-row">
              <label for="contact-email-field">Your email</label>
              <input id="contact-email-field" name="email" type="email" required autocomplete="email" />
            </p>
            <p class="form-row">
              <label for="contact-subject">Subject</label>
              <input id="contact-subject" name="subject" type="text" />
            </p>
            <p class="form-row">
              <label for="contact-message">Message</label>
              <textarea id="contact-message" name="message" rows="6" required></textarea>
            </p>
            <p class="form-submit">
              <button type="submit">Send</button>
            </p>
            <p class="form-thanks" hidden>Thank you — your message has been sent.</p>
          </form>
        </div>
      </div>
    </section>
  </article>
</Layout>

<style>
  .about-section {
    margin-bottom: 3rem;
  }
  .about-section:last-child {
    margin-bottom: 0;
  }
  /* When you click the "Contact" link in the nav, the browser jumps to
     #contact. Give the section a bit of breathing room above so the
     heading doesn't sit flush against the previous content. */
  #contact {
    scroll-margin-top: 1.5rem;
  }

  /* Bio text + portrait column side-by-side on desktop. The right
     column stays at a fixed width so it doesn't dominate the page;
     bio text on the left fills the remaining space. The two photos
     stack vertically inside that right column. */
  .bio-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 2rem;
    align-items: start;
  }
  .bio-photos {
    grid-column: 2;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .bio-photos figure {
    margin: 0;
  }
  .bio-photos img {
    display: block;
    width: 100%;
    height: auto;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.12);
  }
  .bio-text {
    grid-column: 1;
    grid-row: 1;
  }

  /* Phones: photos move above the text, side-by-side at the top so
     both stay visible without endless scrolling before the bio. */
  @media (max-width: 720px) {
    .bio-layout {
      grid-template-columns: 1fr;
    }
    .bio-photos,
    .bio-text {
      grid-column: 1;
      grid-row: auto;
    }
    .bio-photos {
      flex-direction: row;
      gap: 0.75rem;
      justify-content: center;
    }
    .bio-photos figure {
      flex: 1 1 0;
      max-width: 220px;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>(".contact-form").forEach((form) => {
    form.addEventListener("submit", (e) => {
      if (form.dataset.needsEndpoint === "true") {
        e.preventDefault();
        const thanks = form.querySelector<HTMLElement>(".form-thanks");
        form.querySelectorAll<HTMLElement>(".form-row, .form-submit").forEach((r) => {
          r.hidden = true;
        });
        if (thanks) thanks.hidden = false;
      }
    });
  });
</script>
