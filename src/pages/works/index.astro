---
import Layout from "../../layouts/Layout.astro";
import WorkCard from "../../components/WorkCard.astro";
import GalleryControls from "../../components/GalleryControls.astro";
import {
  loadWorksData,
  publishedWorks,
  sortWorksForDisplay,
} from "../../data/works";

// SSR: render the latest works list on each page load. Drops the
// previous `prerender = true` so Nicholas's saves appear instantly.
const data = await loadWorksData();
const list = sortWorksForDisplay(data, publishedWorks(data));
---

<Layout title="Works — Nicholas Hart Khan" isWorksHome={true}>
  <h2 class="page-title">Works</h2>
  {list.length === 0 ? (
    <p class="prose" style="text-align:center;color:var(--color-muted);">
      No works yet.
    </p>
  ) : (
    <>
      <GalleryControls />
      <section class="gallery-grid">
        {list.map((work) => <WorkCard work={work} />)}
      </section>
    </>
  )}
</Layout>
