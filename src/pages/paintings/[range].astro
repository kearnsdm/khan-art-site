---
import Layout from "../../layouts/Layout.astro";
import WorkCard from "../../components/WorkCard.astro";
import GalleryControls from "../../components/GalleryControls.astro";
import {
  loadWorksData,
  publishedWorks,
  sortWorksForDisplay,
} from "../../data/works";
import { loadYearGroups, yearGroupById } from "../../data/year-groups";

// SSR: previously this was prerendered with getStaticPaths against the
// bundled year-groups list. Now we look up the group on each request
// and filter the latest works payload. Lets Nicholas edit year ranges
// and have the resulting pages appear without a rebuild.
const id = Astro.params.range;
const groups = await loadYearGroups();
const group = id ? yearGroupById(groups, id) : undefined;
if (!group) {
  return new Response("Not found", { status: 404 });
}

const data = await loadWorksData();
const min = typeof group.minYear === "number" ? group.minYear : Number.NEGATIVE_INFINITY;
const max = typeof group.maxYear === "number" ? group.maxYear : Number.POSITIVE_INFINITY;
const list = sortWorksForDisplay(
  data,
  publishedWorks(data).filter(
    (w) => typeof w.year === "number" && w.year >= min && w.year <= max
  )
);
---

<Layout title={`${group.pageTitle} — Nicholas Hart Khan`} currentYearGroupId={group.id}>
  <h2 class="page-title">{group.pageTitle}</h2>
  {list.length === 0 ? (
    <p class="prose" style="text-align:center;color:var(--color-muted);">
      No works in this section yet.
    </p>
  ) : (
    <>
      <GalleryControls />
      <section class="gallery-grid">
        {list.map((work) => <WorkCard work={work} />)}
      </section>
    </>
  )}
</Layout>
