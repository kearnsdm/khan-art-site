---
import Layout from "../layouts/Layout.astro";
import Carousel from "../components/Carousel.astro";
import { loadWorksData, featuredImages } from "../data/works";

// SSR: read the live carousel set on each request so Nicholas's edits
// take effect immediately. The Blobs read is fast (~50 ms) and the
// fetched bytes are small.
const data = await loadWorksData();
const slides = featuredImages(data);
---

<Layout>
  <Carousel slides={slides} />
</Layout>
