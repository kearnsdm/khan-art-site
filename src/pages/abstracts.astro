---
import Layout from "../layouts/Layout.astro";
import WorkCard from "../components/WorkCard.astro";
import { worksBySection } from "../data/works";
import { sectionTitles } from "../data/sections";

const list = worksBySection("abstracts");
const title = sectionTitles.abstracts;
---

<Layout title={`${title} — Nicholas Hart Khan`} section="abstracts">
  <h2 class="page-title">{title}</h2>
  {list.length === 0 ? (
    <p class="prose" style="text-align:center;color:var(--color-muted);">No works in this section yet.</p>
  ) : (
    <section class="gallery-grid">
      {list.map((work) => <WorkCard work={work} />)}
    </section>
  )}
</Layout>
