---
import type { Work } from "../data/works";
import { primaryImagePath, primaryImageAlt, workHeadline } from "../data/works";

interface Props {
  work: Work;
}

const { work } = Astro.props;
const src = primaryImagePath(work);
const alt = primaryImageAlt(work);
---

<a class="work-card" href={`/works/${work.slug}`}>
  {src && <img class="work-thumb" src={src} alt={alt} loading="lazy" />}
  <div class="work-meta">
    <p class="work-title">{workHeadline(work)}</p>
  </div>
</a>
