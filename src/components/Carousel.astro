---
import type { Work, WorkImage } from "../data/works";
import { workHeadline } from "../data/works";

export interface FeaturedSlide {
  work: Work;
  image: WorkImage;
  imagePath: string;
}

interface Props {
  slides: FeaturedSlide[];
  autoplayMs?: number;
}

const { slides, autoplayMs = 9000 } = Astro.props;
---

<div class="carousel" data-carousel data-autoplay={autoplayMs.toString()}>
  <div class="slides">
    {slides.map(({ work, image, imagePath }, i) => (
      <a
        class={`slide${i === 0 ? " active" : ""}`}
        href={`/works/${work.slug}`}
        data-index={i.toString()}
        data-headline={workHeadline(work)}
      >
        <img
          src={imagePath}
          alt={`${work.title} painting`}
          loading={i === 0 ? "eager" : "lazy"}
        />
      </a>
    ))}
    <div class="overlay">
      <button type="button" data-prev aria-label="Previous">&larr;</button>
      <button type="button" data-next aria-label="Next">&rarr;</button>
      <span class="indicator" data-indicator>1 / {slides.length}</span>
    </div>
  </div>
  <div class="caption" data-caption>
    {slides[0] && workHeadline(slides[0].work)}
  </div>
</div>

<script>
  type Slide = HTMLAnchorElement;

  function setupCarousel(root: HTMLElement) {
    const slides = Array.from(root.querySelectorAll<Slide>(".slide"));
    if (slides.length === 0) return;

    const indicator = root.querySelector<HTMLElement>("[data-indicator]");
    const caption = root.querySelector<HTMLElement>("[data-caption]");
    const prev = root.querySelector<HTMLButtonElement>("[data-prev]");
    const next = root.querySelector<HTMLButtonElement>("[data-next]");
    const autoplayMs = parseInt(root.dataset.autoplay || "0", 10);

    let index = 0;
    let timer: number | undefined;

    function render() {
      slides.forEach((s, i) => s.classList.toggle("active", i === index));
      if (indicator) indicator.textContent = `${index + 1} / ${slides.length}`;
      if (caption) {
        const slide = slides[index];
        caption.textContent = slide?.dataset.headline ?? "";
      }
    }

    function go(delta: number) {
      index = (index + delta + slides.length) % slides.length;
      render();
      restart();
    }

    function restart() {
      if (timer) window.clearInterval(timer);
      if (autoplayMs > 0 && slides.length > 1) {
        timer = window.setInterval(() => go(1), autoplayMs);
      }
    }

    prev?.addEventListener("click", (e) => { e.preventDefault(); go(-1); });
    next?.addEventListener("click", (e) => { e.preventDefault(); go(1); });
    root.addEventListener("mouseenter", () => { if (timer) window.clearInterval(timer); });
    root.addEventListener("mouseleave", restart);

    restart();
  }

  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach(setupCarousel);
</script>
